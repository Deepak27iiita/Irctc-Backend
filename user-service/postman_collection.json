{
	"info": {
		"name": "User Service API - iRctc",
		"description": "Postman Collection for the User Service.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:{{PORT}}/health",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "{{PORT}}",
					"path": [
						"health"
					]
				}
			}
		},
		{
			"name": "Root",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:{{PORT}}/",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "{{PORT}}",
					"path": [
						""
					]
				}
			}
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Send OTP (Register Step 1)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"test@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"confirmPassword\": \"SecurePass123!\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "http://localhost:{{PORT}}/api/v1/auth/send-otp",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "{{PORT}}",
							"path": [
								"api",
								"v1",
								"auth",
								"send-otp"
							]
						}
					}
				},
				{
					"name": "Verify OTP (Register Step 2)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"otp\": \"123456\",\n  \"otpSessionId\": \"paste-session-id-here\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "http://localhost:{{PORT}}/api/v1/auth/verify-otp",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "{{PORT}}",
							"path": [
								"api",
								"v1",
								"auth",
								"verify-otp"
							]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "PORT",
			"value": "3000",
			"type": "string"
		}
	]
}
